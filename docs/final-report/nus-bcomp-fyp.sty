% Used with memoir document class

\ProvidesPackage{nus-bcomp-fyp}

\RequirePackage{geometry}
\geometry{a4paper}

\RequirePackage{graphicx}

\RequirePackage{changepage}

\newcommand{\supervisor}[1]{\gdef\@supervisor{#1}}
\newcommand{\department}[1]{\gdef\@dept{#1}}
\newcommand{\faculty}[1]{\gdef\@faculty{#1}}
\newcommand{\university}[1]{\gdef\@university{#1}}
\newcommand{\academicyear}[1]{\gdef\@academicyear{#1}}
\newcommand{\projectno}[1]{\gdef\@projectno{#1}}
\newcommand{\advisor}[1]{\gdef\@advisor{#1}}

\newcommand{\makecover}{
    \null
    \thispagestyle{empty}
    \vspace*{\fill}
    \begin{center}
        {B.Comp. Dissertation \\}
        \vspace{1.4in}
        {\Large\bfseries\@title} \\
        \vspace{1.4in}
        {By \\ \@author \\}
        \vspace{2in}
        {\@dept \\ \@faculty \\ \@university \\}
        \vspace{0.3in}
        {\@academicyear}
    \end{center}
    \vspace*{\fill}
    \null
    \clearpage
}

\renewcommand{\maketitle}{
    \null
    \thispagestyle{empty}
    \vspace*{\fill}
    \begin{center}
        {B.Comp. Dissertation \\}
        \vspace{0.9in}
        {\Large\bfseries\@title} \\
        \vspace{0.9in}
        {By \\ \@author \\}
        \vspace{1.6in}
        {\@dept \\ \@faculty \\ \@university \\}
        \vspace{0.3in}
        {\@academicyear}
    \end{center}
    \vspace*{\fill}
    \null
    Project No: \@projectno \\
    Advisor: \@advisor \\
    Deliverables:
    \null
}

% Paragraph spacing
\nonzeroparskip
\setlength{\parindent}{0pt}
\OnehalfSpace

% Chapter title styling
\renewcommand{\insertchapterspace}{}
\setlength{\afterchapskip}{1.5\onelineskip}
\renewcommand{\chapterheadstart}{\clearforchapter}
\renewcommand{\chapterheadstart}{\clearforchapter}
\renewcommand{\chaptitlefont}{\SingleSpacing\centering\normalfont\large\bfseries}
\renewcommand{\printchaptername}{}
\renewcommand{\printchapternum}{}
\renewcommand{\printchaptertitle}[1]{\chaptitlefont{#1}}

% Rename Contents
\renewcommand{\contentsname}{Table of Contents}
